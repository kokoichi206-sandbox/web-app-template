# package.json の engines 制約を厳格に適用し、許可されていない Node.js での実行を拒否する。
engine-strict=true

# package.json の packageManager 記述と完全一致する pnpm だけを許容して環境差異を排除。
package-manager-strict-version=true

# packageManager で宣言した pnpm を自動ダウンロードし、常に同じバージョンで実行する。
manage-package-manager-versions=true

# lockfile を更新せずに解決できない場合のみ失敗させ、意図しない依存更新を防ぐ。
prefer-frozen-lockfile=true

# ピア依存関係の欠落やバージョン不一致を即エラーにして、潜在的な実行時クラッシュを早期検知する。
strict-peer-dependencies=true

# package.json の記述も lockfile 同様に固定して、依存範囲の揺らぎを防ぐ。
save-exact=true
